. 
. * VAM calculation
. capture program drop fun_vam

. program define fun_vam
  1.         args outcome cov_opt
  2.                 * args:
.                 *       "outcome": outcome variable of interest (e.g., anysc1
> 621, mathscal) 
.                 *       "cov_opt": indicator for whether or not to include th
> e "excluded" adjustment controls in the VAM calculation. 
. 
.         if ("${vam_measure}" == "jackson") | ("${vam_measure}" == "naive") | 
> ("${vam_measure}" == "blp") | ("${vam_measure}" == "none") {
  3. 
.                 *** 1) Calculate residuals and LOO VAMs (w/t EB shrinkage)
.                 if `cov_opt' == 1 {
  4.                         qui areg `outcome' ${covdesign} ${covsadj}, abs(te
> achid)        
  5.                 }
  6.                 else {
  7.                         qui areg `outcome' ${covdesign}, abs(teachid)   
  8.                 }
  9.                 predict score_r, dresiduals
 10.                 predict xhat, xb
 11.                 predict xhatd, xbd
 12.                 gen teach_fe = xhatd - xhat
 13. 
.                 *** 2) Build teacher-year-subject level dataset
.                 bysort teachid year: egen double ebar_jt = mean(score_r)
 14.                 qui sum ebar_jt
 15.                 replace ebar_jt = ebar_jt - r(mean)
 16. 
.                 * Recentered leave-year-out ebar
.                 bysort teachid: egen double res_j_total = total(score_r)
 17.                 bysort teachid year: egen double res_jt_total = total(scor
> e_r)
 18.                 bysort teachid: egen double n_j = count(score_r)
 19.                 bysort teachid year: egen double n_jt = count(score_r)
 20. 
.                 gen double loo_ebar_jt = (res_j_total - res_jt_total)/(n_j - 
> n_jt)
 21.                 qui sum loo_ebar_jt
 22.                 replace loo_ebar_jt = loo_ebar_jt - r(mean)
 23.                 bysort teachid: egen nyears_j = nvals(year)
 24. 
.                 * Leave out school-grade
.                 bysort teachid school_fe grade: egen double res_j_total_schgr
> ade = total(score_r)
 25.                 bysort teachid school_fe grade: egen double n_j_schgrade =
>  count(score_r)
 26.                 gen loo_ebar_schgrade = (res_j_total - res_j_total_schgrad
> e) / (n_j - n_j_schgrade)
 27.                 gen ebar_schgrade = res_j_total_schgrade / n_j_schgrade
 28. 
.                 * Leave out school
.                 bysort teachid school_fe: egen double res_j_total_school = to
> tal(score_r)
 29.                 bysort teachid school_fe: egen double n_j_school = count(s
> core_r)
 30.                 gen loo_ebar_school = (res_j_total - res_j_total_school) /
>  (n_j - n_j_school)
 31.                 gen ebar_school = res_j_total_school / n_j_school
 32.                 
.                 * Get total students and scores from other years
.                 preserve 
 33.                 collapse (mean) n_jt res_jt_total, by(teachid year subject
> )
 34.                 rename n_jt n_jtm1 
 35.                 rename res_jt_total res_jtm1_total
 36.                 rename year merge_year
 37.                 tempfile twoyearlom
 38.                 save `twoyearlom', replace
 39.                 restore
 40. 
.                 * Leave outs of additional years
.                 gen double loo_ebar_jt2 = (res_j_total - res_jt_total)
 41.                 gen double loo_denom_tmp = (n_j - n_jt)
 42. 
.                 foreach k of numlist 1/2 {
 43.                         capture drop merge_year
 44.                         gen merge_year = year - `k'
 45.                         merge m:1 teachid merge_year subject using `twoyea
> rlom', nogen keep(1 3)
 46.                                 replace loo_ebar_jt2 = loo_ebar_jt2 - res_
> jtm1_total
 47.                                 replace loo_denom_tmp = loo_denom_tmp - n_
> jtm1
 48.                                 if `k' == 1 {
 49.                                         gen loo_ebar_jtm1 = loo_ebar_jt2/l
> oo_denom_tmp
 50.                                 }
 51.                                 drop res_jtm1_total n_jtm1
 52. 
.                         capture drop merge_year
 53.                         gen merge_year = year + `k'
 54.                         merge m:1 teachid merge_year subject using `twoyea
> rlom', nogen keep(1 3)
 55.                                 replace loo_ebar_jt2 = loo_ebar_jt2 - res_
> jtm1_total
 56.                                 replace loo_denom_tmp = loo_denom_tmp - n_
> jtm1
 57.                                 if `k' == 1 {
 58.                                         gen loo_ebar_jtm1p1 = loo_ebar_jt2
> /loo_denom_tmp
 59.                                         gen loo_ebar_jtp1 = (res_j_total -
>  res_jt_total - res_jtm1_total)/(n_j - n_jt - n_jtm1)
 60.                                 }
 61.                                 drop res_jtm1_total n_jtm1
 62.                 }
 63.                 
.                 replace loo_ebar_jt2 = loo_ebar_jt2/loo_denom_tmp
 64.                 replace loo_ebar_jt2 = . if loo_denom_tmp <= 0 | loo_denom
> _tmp == .
 65.                 drop loo_denom_tmp
 66. 
.                 qui sum loo_ebar_jt2
 67.                 replace loo_ebar_jt2 = loo_ebar_jt2 - r(mean)
 68. 
.                 qui sum loo_ebar_jtm1
 69.                 replace loo_ebar_jtm1 = loo_ebar_jtm1 - r(mean)
 70. 
.                 if "$vam_measure" == "none" {
 71.                         gen vam  = loo_ebar_jt
 72.                         gen vaml2 = loo_ebar_jtm1
 73.                         gen vaml3 = loo_ebar_jtm1p1
 74.                         gen vaml4 = loo_ebar_jt2
 75.                         gen vamlf1 = loo_ebar_jtp1
 76.                         gen resid = score_r - vam
 77.                         gen yhat = xhat + vam
 78.                 }
 79.                 else if "$vam_measure" == "blp" {
 80.                         * BLP using LOO mean
.                         reg ebar_jt ibn.nyears_j#c.loo_ebar_jt
 81.                         predict vam, xb
 82.                         gen resid = score_r - vam
 83.                         gen yhat = xhat + vam
 84. 
.                         * BLP using leave out t and t-1
.                         reg ebar_jt ibn.nyears_j#c.loo_ebar_jtm1
 85.                         predict vaml2, xb
 86. 
.                         * BLP using leave out t, t-1 and t+1
.                         reg ebar_jt ibn.nyears_j#c.loo_ebar_jtm1p1
 87.                         predict vaml3, xb
 88. 
.                         * BLP using leave out t, t-1, t-2, t+1 and t+2
.                         reg ebar_jt ibn.nyears_j#c.loo_ebar_jt2
 89.                         predict vaml4, xb
 90.                 }
 91. 
.                 else if "$vam_measure" == "naive" {
 92. 
.                         *** lambda (shrinkage)
.                         * _tmp_n_jt
.                         capture drop _tmp_n_jt
 93.                         bysort teachid year: gen double _tmp_n_jt = n_jt^2
>  if _n == 1
 94.                         
.                         capture drop total_n_jt2_loo
 95.                         bysort teachid: egen total_n_jt2_loo = total(_tmp_
> n_jt)
 96.                         replace total_n_jt2_loo = total_n_jt2_loo - n_jt^2
 97.                         capture drop _tmp_n_jt
 98. 
.                         capture drop _lambda_jt
 99.                         gen double _lambda_jt = (total_n_jt2_loo/(n_jt_oth
> er^2))*`var_classroom' + `var_e'/(n_jt_other) + `var_teacher_effects'
100.                         bysort teachid year: replace _lambda_jt = . if _n 
> > 1
101.                         qui sum _lambda_jt
102.                         capture drop lambda
103.                         gen double lambda = `var_teacher_effects'/r(mean)
104. 
.                         * VAM with naive shrinkage
.                         capture drop vam_naiveeb
105.                         gen double vam_naiveeb = lambda*loo_ebar_jt
106.                 }
107.                 else if "${vam_measure}" == "jackson"{
108.                         *** 3) Notes: To conduct Jackson/Kane and Staigr E
> B procedure we need several variances
.                         * Variance of residuals (=Var_e + Var_teachers + Var_
> classroom) 
.                         qui sum score_r
109.                         local var_res=r(sd)^2
110. 
.                         * Variance of within-class error term (Var_e)
.                         capture drop classYear
111.                         egen classYear = group(teachid year)
112. 
.                         areg score_r, abs(classYear) 
113.                         capture drop _tmpres
114.                         predict _tmpres, residuals
115.                         qui sum _tmpres
116.                         local var_e=r(sd)^2
117.                         drop _tmpres
118. 
. 
.                         * Variance of teacher effects --- will be done by ran
> dom matches of classrooms
.                         * We will use both methods and compare. But first bui
> lt data in a format of a classroom residuals
.                         preserve
119.                         keep teachid year n_jt ebar_jt
120.                         duplicates drop 
121. 
.                         * Variance of teacher effects using random matching o
> f classrooms
.                         * random match of classrooms within a teacher
.                         global numiters = 200
122.                         mat sims = J(${numiters},1,.)
123.                         local cc = 1
124.                         forvalues itr = 1(1)$numiters{
125.                                 dis "Working on iteration `itr'"
126.                                 capture drop _draw _random_match
127.                                 gen double _draw = runiform() 
128.                                 sort teachid _draw
129.                                 by teachid: gen _random_match = _n
130. 
.                                 forvalues ss = 1(1)2{
131.                                         capture drop *ebar`ss' 
132.                                         gen _ebar`ss' = ebar_jt if _random
> _match == `ss'        
133.                                         by teachid: egen ebar`ss' = max(_e
> bar`ss')
134.                                 }
135.                                 corr ebar1 ebar2 if _random_match == 1, co
> variance
136.                                 mat sims[`cc',1] = r(cov_12)
137.                                 local ++cc
138.                         }
139.                         svmat sims
140.                         rename sims1 sims
141.                         sum sims, d
142.                         local var_teacher_effects = r(p50)
143.                         restore
144. 
.                         * Variance of classroom effects
.                         local var_classroom = `var_res' - `var_e' - `var_teac
> her_effects'
145. 
.                         *** 4) EB shrinkage
.                         local cc = 1
146.                         levelsof year, local(_listyears)
147.                         foreach yr of local _listyears{
148.                                 dis "Working on year: `yr'"
149.                                 preserve
150.                                 keep teachid year n_jt ebar_jt
151.                                 duplicates drop 
152.                                 drop if year == `yr'
153. 
.                                 gen double h_jt = 1/(`var_classroom' + `var_e
> '/n_jt )
154.                                 gen h_by_ebar_jt=ebar_jt/(`var_classroom' 
> + `var_e'/n_jt )
155.                                 bysort teachid: egen denominator=total(h_j
> t)
156.                                 bysort teachid: egen numerator=total(h_by_
> ebar_jt)
157.                                 gen double ebar_j= numerator/denominator
158.                                 gen double vam_eb = ebar_j*(`var_teacher_e
> ffects'/(`var_teacher_effects'+(1/denominator)))
159. 
.                                 * Save to a temp file
.                                 keep vam_eb teachid
160.                                 duplicates drop
161.                                 gen year = `yr'
162. 
.                                 if `cc' == 1{
163.                                         tempfile vamEB
164.                                         save vamEB, replace               
>               
165.                                 }
166.                                 else{
167.                                         append using vamEB
168.                                         save vamEB, replace
169.                                 }
170.                                 restore
171.                                 local ++cc
172.                         }
173. 
.                         * Merge back
.                         merge m:1 teachid year using vamEB, nogen
174.                 }
175. 
.                 dis "SD of teacher effects is: `var_teacher_effects'"
176.                 dis "SD of classroom shocks is: `var_classroom'"
177.                 dis "SD of individual within-classroom residuals is: `var_
> e'"
178.         }
179.         else if "${vam_measure}" == "chetty"{
180.                 *Chetty's version of vam (he just uses something he calls 
> "score")
.                 capture drop classChetty score_r
181.                 egen classChetty = group(teachid year)
182.                 global dtadir "temp/"
183.                 if `cov_opt' == 1{
184.                         vam `outcome', teacher(teachid) year(year) class(c
> lassChetty) controls(${covdesign} ${covsadj}) output("$dtadir/tfx") tfx_resid
> (teachid) driftlimit(5) data(merge tv score_r) quasiexperiment
185.                 }
186.                 else{
187.                         vam `outcome', teacher(teachid) year(year) class(c
> lassChetty) controls(${covdesign}) output("$dtadir/tfx") tfx_resid(teachid) d
> riftlimit(5) data(merge tv score_r) quasiexperiment
188.                 }               
189.                 rename tv vam
190.                 rename tv_2yr_l vaml2
191.                 rename tv_ss vaml4
192.                 gen vaml3 = vaml4
193.                 gen yhat = vaml3
194.         }
195.         else if "${vam_measure}" == "MElogit"{
196.                 
.                 melogit `outcome' $covdesign || teachid:
197.                 * estimates store melgtNoDemo
. 
.                 capture drop vam_melgt
198.                 gen vam_melgt = .
199.                 levelsof year, local(_tmp)
200.                 foreach yy of local _tmp{
201.                         dis `Working on LOO VAM/EBmeans of year: yy'
202.                         capture drop _tmpyear*
203.                         predict _tmpyear if year != `yy', remeans
204.                         bysort teachid: egen double _tmpyear2 = max(_tmpye
> ar)
205.                         assert vam_melgt ==. if year == `yy'
206.                         replace vam_melgt =  _tmpyear2 if year == `yy'
207.                 }
208.         }
209.         else {
210.                 dis "NO valid VAM measure specified"
211.         }
212. end

. 
. 
end of do-file

. 
. * Get the residuals
. foreach var of varlist  aoc_any aoc_crim aoc_traff aoc_index aoc_incar gpa_we
> ighted class_rank_w college_bound grad {
  2.     areg `var' $covdesign, abs(teachid)   
  3.     predict `var'_r, dresiduals 
  4. }
