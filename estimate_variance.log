. 
. foreach prefix in "" "lead1_" "lead2_" "lead3_" "lead4_" {
  2.     foreach var of varlist testscores any_discp studypca {
  3.         areg `prefix'`var' $covdesign, abs(teachid)    
  4.         predict `prefix'`var'_r, dresiduals 
  5.     }
  6. 
.     areg `prefix'mathscal $covdesign if subject == "math" | subject == "hr", 
> abs(teachid)    
  7.     predict `prefix'math_r, dresiduals 
  8. 
.     areg `prefix'readscal $covdesign if subject == "eng" | subject == "hr", a
> bs(teachid)    
  9.     predict `prefix'eng_r, dresiduals 
 10. 
.     if "`prefix'" != "lead4_" {
 11.         areg `prefix'behavpca $covdesign, abs(teachid)    
 12.         predict `prefix'behave_r, dresiduals 
 13.     }
 14. }
