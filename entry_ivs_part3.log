. program define vam
  1.         
.         version 10.1
  2. 
.         set more off
  3. 
.         syntax varname(ts fv), teacher(varname) year(varname) class(varname) 
> [ ///
>                 by(varlist) ///
>                 controls(varlist ts fv) absorb(varname) tfx_resid(varname) //
> /
>                 data(string) output(string) output_addvars(varlist) ///
>                 driftlimit(integer -1) ///
>                 QUASIexperiment]
  4. 
.         * Error checks
.         local depvar `varlist'
  5.         
.         capture confirm variable score_r, exact
  6.         if (_rc==0) {
  7.                 di as error "The dataset loaded in memory when vam is run 
> cannot have a variable named score_r."
  8.                 exit 110
  9.         }
 10.         
.         capture confirm variable tv, exact
 11.         if (_rc==0) {
 12.                 di as error "The dataset loaded in memory when vam is run 
> cannot have a variable named tv."
 13.                 exit 110
 14.         }
 15.         
.         if ("`quasiexperiment'"!="") {
 16.                 capture confirm variable tv_2yr_l, exact
 17.                 if (_rc==0) {
 18.                         di as error "The dataset loaded in memory when vam
>  is run cannot have a variable named tv_2yr_l."
 19.                         exit 110
 20.                 }
 21.                 
.                 capture confirm variable tv_2yr_f, exact
 22.                 if (_rc==0) {
 23.                         di as error "The dataset loaded in memory when vam
>  is run cannot have a variable named tv_2yr_f."
 24.                         exit 110
 25.                 }
 26.                 
.                 capture confirm variable tv_ss, exact
 27.                 if (_rc==0) {
 28.                         di as error "The dataset loaded in memory when vam
>  is run cannot have a variable named tv_ss."
 29.                         exit 110
 30.                 }
 31.         }
 32.         
.         local merge_tv=0
 33.         local merge_resid=0
 34.         if ("`data'"=="") local data="preserve"
 35.         else {
 36.                 if !inlist("`data'","preserve","tv","merge tv","merge scor
> e_r","merge tv score_r","merge score_r tv","variance") {
 37.                         di as error "Not a valid argument for data. Choose
>  either 'preserve', 'tv', 'merge [tv AND/OR score_r]', or 'variance'."
 38.                         exit 198
 39.                 }
 40.                 else {
 41.                         tokenize "`data'"
 42.                         if ("`1'")=="merge" {
 43.                                 if ("`2'"=="tv") | ("`3'"=="tv") local mer
> ge_tv=1
 44.                                 if ("`2'"=="score_r") | ("`3'"=="score_r")
>  local merge_resid=1
 45.                         }
 46.                 }
 47.         }       
 48.         
.         if "`tfx_resid'"!="" & "`absorb'"!="" {
 49.                 di as error "Cannot specify an absorb variable and a tfx_r
> esid variable simultaneously."
 50.                 exit 198
 51.         }
 52.         
.         * If output was left blank, set a tempfile for the tv output
.         if `"`output'"'=="" {
 53.                 tempfile output
 54.                 local nooutput=1
 55.         }
 56.         else local nooutput=0
 57.         
.         * Start log
.         if (`nooutput'!=1) log using `"`output'_log"', replace
 58.         
.         * Process by variables
.         if ("`by'"!="") {
 59.                 tempvar byvar
 60.                 egen `byvar'=group(`by'), label
 61.                 sum `byvar', meanonly
 62.                 local by_vals=`r(max)'
 63.         }
 64.         else local by_vals=1
 65. 
.         ****************
.         
.         preserve
 66.         
.         *** Run through separately for each by-value.
.         local firstloop=1
 67.         forvalues l=1/`by_vals' {
 68.         
.                 if (`firstloop'!=1) restore, preserve
 69.                 
.                 *** Print heading (with by-variable identifier if applciable)
.                 di "{txt}{hline}"
 70.                 if ("`by'"!="") {
 71.                         local bylabel : label `byvar' `l', strict
 72.                         di "{bf:-> by variables:} `by' = `bylabel'"
 73.                 }
 74. 
.                 *** Drop invalid observations ***
.                 qui drop if missing(`teacher',`year',`class')
 75. 
.                 *** Keep only the correct by-value
.                 if ("`by'"!="") qui keep if `byvar'==`l'
 76.                 
.                 *** Run regression
.                 
.                 * If absorb or tfx_resid is not empty (only one is non-empty,
>  otherwise an error was thrown), use areg 
.                 if "`absorb'"!="" | "`tfx_resid'"!="" {
 77.                         qui areg `depvar' `controls' , absorb(`absorb'`tfx
> _resid')
 78.                 }
 79.                 * If absorb and tfx_resid are both empty, run regular regr
> ession
.                 else {
 80.                         qui reg `depvar' `controls'
 81.                 }
 82.                 
.                 *** Predict residuals
.                 
.                 * If tfx_resid is empty, predict residuals
.                 if "`tfx_resid'"=="" {
 83.                         qui predict score_r if e(sample),r 
 84.                 }
 85.                 * If tfx_resid was specified, predict residuals + absorbed
>  teacher fixed effects
.                 else {
 86.                         qui predict score_r if e(sample), dresiduals
 87.                 }
 88.                 
.                 *** Save residuals to a dataset if merging them later
.                 if `merge_resid'==1 {
 89.                         tempfile resid_data_`l'                 
 90.                         qui save `"`resid_data_`l''"', replace
 91.                 }
 92. 
.                 *** Save number of parameters
.                 
.                 tempname num_obs num_par
 93.                 
.                 scalar `num_obs' = e(N)
 94. 
.                 * If absorb is not empty (and tfx_resid is), save (number of 
> slopes + number of clusters + 1)
.                 if "`absorb'"!="" {
 95.                         scalar `num_par' = e(df_m) + e(df_a) + 1
 96.                 }
 97.                 * Otherwise, save (number of slopes + 1)
.                 else {
 98.                         scalar `num_par' = e(df_m) + 1
 99.                 }
100. 
.                 *** Create var for number of students in class
.                 tempvar n_tested
101.                 qui bys `teacher' `year' `group' `class': egen `n_tested' 
> = count(score_r)
102. 
.                 *** Compute total variance ***
.                 tempvar class_mean index
103.                 qui by `teacher' `year' `group' `class': egen `class_mean'
>  = mean(score_r) 
104.                 qui by `teacher' `year' `group' `class': g `index' = _n
105. 
.                 tempname var_total
106.                 qui sum score_r
107.                 scalar `var_total' = r(Var)*((`num_obs' - 1)/(`num_obs' - 
> `num_par'))
108.                 
.                 *** Compute individual variance (i.e. within class variance)
.                 *--> note that we use rmse instead of direct variance of resi
> duals here to deal with fact that class effects have not been shrunk
.                 tempname num_class var_ind var_class
109. 
.                 tempvar individual_dev_from_class
110.                 qui gen `individual_dev_from_class' = score_r - `class_mea
> n'
111.                 
.                 qui count if `index'==1 & `n_tested'!=0
112.                 scalar `num_class' = r(N)
113. 
.                 qui sum `individual_dev_from_class'
114.                 scalar `var_ind' = r(Var)*((`num_obs' - 1)/(`num_obs' - `n
> um_class' - `num_par' + 1))
115. 
. 
.                 ********** Collapse to class-level data **********
.                 
.                 qui by `teacher' `year' `group' `class': keep if _n==1
116. 
.         
.                 *** Estimate covariance of two classes taught by same teacher
>  in the same year
.                 set seed 9827496
117.                 tempvar rand classnum
118.                 g `rand'=uniform()
119.                 bys `teacher' `year' (`rand'): gen `classnum'=_n
120.                 
.                 * If there are multiple classes per teacher-year cell, comput
> e the covariance.
.                 * Otherwise set to 0. Will display as missing in output, but 
> internally set to 0 because it will never appear in the VCV, but the way thin
> gs are coded requires that it be non-missing.
.                 tempname cov_sameyear corr_sameyear obs_sameyear
121.                 qui sum `classnum'
122.                 if (r(max)==1) {
123.                         local missing_sameyear=1
124.                         scalar `cov_sameyear'=0
125.                 }
126.                 else {
127.                         local missing_sameyear=0
128.                         tempvar identifier
129.                         egen `identifier'=group(`teacher' `year')
130.                         qui tsset `identifier' `classnum'/*, noquery*/
131.                         qui corr `class_mean' f.`class_mean' [aw=`n_tested
> '+f.`n_tested'], cov
132.                         scalar `cov_sameyear'=r(cov_12)
133.                         scalar `corr_sameyear'=r(cov_12) / ( sqrt(r(Var_1)
> ) * sqrt(r(Var_2)) )
134.                         scalar `obs_sameyear'=r(N)
135.                 }
136.                 
.                 *** Compute the variance of the class-level shock.  Hits all 
> kids in the class in the same way, but is unrelated across classes even taugh
> t by the same teacher in the same year.
.                 scalar `var_class' = `var_total' - `var_ind' - `cov_sameyear'
137.                 if (`var_class'<0) {
138.                         di as error "Note: var_class has been computed as 
> being less than 0."
139.                         di "var_class is defined as = var_total - var_ind 
> - cov_sameyear."
140.                         di "Computed variances: var_total, var_ind, cov_sa
> meyear, var_class"
141.                         di `var_total',`var_class',`var_ind',`cov_sameyear
> '
142.                         di "This negative variance can occur because cov_s
> ameyear is calculated using only the subsample of observations that teach mul
> tiple classes per year (in the same by-group)."
143.                 }
144.                 
.                 tempvar weight
145.                 qui g `weight'=1/(`var_class' + `var_ind'/`n_tested')
146.                 
.                 *** Keep teacher-years which have no weight
.                 
.                 tempvar excess_weight
147.                 qui gen `excess_weight'=(missing(`weight'))
148. 
.                 qui replace `weight'=1 if missing(`weight')
149.                 * note: adding this weight doesn't affect the class_mean, 
> because missing observations are not included in the mean computation.  it on
> ly affects the rawsum of weight, and so we remove it afterward.
. 
.                 
.                 ********** Collapse to teacher-year level data using precisio
> n weights **********
.                 collapse (mean) `class_mean' (rawsum) `weight' `n_tested' `ex
> cess_weight' [aw=`weight'], by(`teacher' `year' `by') fast
150.                 
.                 * Remove the excess weight used to keep missing scores
.                 qui replace `weight'=`weight'-`excess_weight'
151.                 
.                 *** Estimate the covariance of years t and t+i for every i, a
> nd store in vector m
.                 qui tsset `teacher' `year'/*, noquery*/
152.                 
.                 tempvar minyear maxyear diff validyear minvalidyear maxvalidy
> ear diffvalid
153.                 
.                 qui bys `teacher': egen `minyear'=min(`year')
154.                 qui by `teacher': egen `maxyear'=max(`year')
155.                 qui g `diff'=`maxyear'-`minyear'
156.                 qui sum `diff'
157.                 local maxspan=`r(max)'
158.                 
.                 qui gen `validyear'=`year' if !missing(`class_mean')
159.                 qui by `teacher': egen `minvalidyear'=min(`validyear')
160.                 qui by `teacher': egen `maxvalidyear'=max(`validyear')
161.                 qui g `diffvalid'=`maxvalidyear'-`minvalidyear'
162.                 qui sum `diffvalid'
163.                 local maxscorespan=`r(max)'
164.                 
.                 if (`maxscorespan'<`maxspan') & (`driftlimit'<=0) {
165.                         di as error _n  "error: The maximum lags of teache
> r data is `maxspan', but the maximum lags of teacher data with class scores i
> s `maxscorespan'."
166.                         di as error             "       You must either se
> t driftlimit() <= `maxscorespan', or drop observations so that the spans are 
> no longer mismatched."
167.                         exit 499
168.                 }
169.                 if (`driftlimit'>`maxscorespan') {
170.                         di as error "error: driftlimit(`driftlimit') was s
> pecified, which is greater than the number of lags (`maxscorespan') in the da
> ta."
171.                         exit 499
172.                 }
173.                 
.                 mata:CC=compute_cov_corr("`class_mean'","`n_tested'",`maxscor
> espan',"`teacher'")
174.                 
.                 if (`driftlimit'>0)     mata:m=create_m(CC[.,1],st_numscalar(
> "`cov_sameyear'"),`maxspan',`driftlimit')
175.                 else                            mata:m=create_m(CC[.,1],st
> _numscalar("`cov_sameyear'"))
176.                 
.                 *** Print estimated variances and covariances           
.                 di "Standard deviations: total, classes, students, teachers s
> ame year"
177.                 if (`missing_sameyear'==0) di sqrt(`var_total'),sqrt(`var_
> class'),sqrt(`var_ind'),sqrt(`cov_sameyear')
178.                 else di sqrt(`var_total'),sqrt(`var_class'),sqrt(`var_ind'
> ),.
179.                 
.                 di "Covariances (left), correlations (middle), observations (
> right).  Row i indicates the relation between year t and t+i:"
180.                 mata:CC[.,1..3]
181.                 
.                 if (`driftlimit'>0) {
182.                         di "Drift limit specified:"
183.                         di `driftlimit'
184.                         
.                         di "Covariances used for VA computations:"
185.                         mata: m[2..length(m)]'
186.                 }
187.                 
.                 mata:check_m_nomissing(m)
188.                 
.                 *** Accumulate the estimated variances/covariances/correlatio
> ns across by-vals
.                 if (`firstloop'==1) {
189.                         mata:cov_lag_accum= CC[.,1]
190.                         mata:corr_lag_accum= CC[.,2]
191.                         mata:obs_lag_accum= CC[.,3]
192.                         mata:cov_se_lag_accum= CC[.,4]
193.                         mata:var_total_accum=   st_numscalar("`var_total'"
> )
194.                         mata:var_class_accum=   st_numscalar("`var_class'"
> )
195.                         mata:var_ind_accum=     st_numscalar("`var_ind'")
196.                         
.                         if (`missing_sameyear'==1) {
197.                                 mata:cov_sameyear_accum=.
198.                                 mata:corr_sameyear_accum=.
199.                                 mata:obs_sameyear_accum=0
200.                         }
201.                         else {
202.                                 mata:cov_sameyear_accum=st_numscalar("`cov
> _sameyear'")
203.                                 mata:corr_sameyear_accum=st_numscalar("`co
> rr_sameyear'")
204.                                 mata:obs_sameyear_accum=st_numscalar("`obs
> _sameyear'")
205.                         }
206.                 }
207.                 else {
208.                         mata:cov_lag_accum=             rightAppendMatrice
> s(cov_lag_accum,CC[.,1])
209.                         mata:corr_lag_accum=    rightAppendMatrices(corr_l
> ag_accum,CC[.,2])
210.                         mata:obs_lag_accum=             rightAppendMatrice
> s(obs_lag_accum,CC[.,3])
211.                         mata:cov_se_lag_accum=  rightAppendMatrices(cov_se
> _lag_accum,CC[.,4])
212.                         mata:var_total_accum=   var_total_accum,st_numscal
> ar("`var_total'")
213.                         mata:var_class_accum=   var_class_accum,st_numscal
> ar("`var_class'")
214.                         mata:var_ind_accum=             var_ind_accum,st_n
> umscalar("`var_ind'")
215.                         
.                         if (`missing_sameyear'==1) {
216.                                 mata:cov_sameyear_accum= cov_sameyear_accu
> m,.
217.                                 mata:corr_sameyear_accum= corr_sameyear_ac
> cum,.
218.                                 mata:obs_sameyear_accum= obs_sameyear_accu
> m,.
219.                         }
220.                         else {
221.                                 mata:cov_sameyear_accum=cov_sameyear_accum
> ,st_numscalar("`cov_sameyear'")
222.                                 mata:corr_sameyear_accum=corr_sameyear_acc
> um,st_numscalar("`corr_sameyear'")
223.                                 mata:obs_sameyear_accum=obs_sameyear_accum
> ,st_numscalar("`obs_sameyear'")
224.                         }
225.                 }
226.                 
.                 *********
.                         
.                 * Count the number of obs for each teacher
.                 sort `teacher' `year'
227.                 tempvar obs_teacher
228.                 by `teacher': egen `obs_teacher'=count(`teacher')
229. 
.                 * Compute teacher VA
.                 qui gen float tv=.
230.                 
.                 if "`quasiexperiment'"!="" {
231.                         qui gen float tv_2yr_l=.
232.                         qui gen float tv_2yr_f=.
233.                         qui gen float tv_ss=.
234.                         
.                         mata: driftcalclist(vectorToStripeDiag(m), "`teacher'
> ", "`year'", "`class_mean'", "`weight'", "`obs_teacher'", "tv", "tv_2yr_l", "
> tv_2yr_f", "tv_ss")
235.                 }
236.                 else mata:driftcalclist(vectorToStripeDiag(m), "`teacher'"
> , "`year'", "`class_mean'", "`weight'", "`obs_teacher'", "tv")
237.                 
.         
.                 * Save the VA estimates to a dataset
.                 if ("`quasiexperiment'"=="") keep `teacher' `year' `by' tv
238.                 else keep `teacher' `year' `by' tv tv_2yr_l tv_2yr_f tv_ss
239.                 
.                 if (`firstloop'!=1) append using `"`output'"', nolabel
240.                 qui save `"`output'"', replace
241. 
.                 * Turn firstloop counter off
.                 local firstloop=0
242.         }
243.         
.         di "{txt}{hline}"
244.         
.         * Save VA estimates
.         if "`output_addvars'"!="" quietly {
245.                 restore, preserve
246.                 keep `teacher' `year' `by' `output_addvars' 
247.                 bys `teacher' `year' `by' `output_addvars': keep if _n==1
248.                 merge m:1 `teacher' `year' `by' using `"`output'"', nogen 
> nolabel
249.         }
250.         sort `teacher' `year' `by'
251.         qui save `"`output'"', replace
252.         
.         * Save "variances / covariances / correlations" dataset to csv
.         if ("`by'"!="") {
253.                 local bylabels=""
254.                 forvalues i=1/`by_vals' {
255.                         local bylabel : label `byvar' `i', strict
256.                         local bylabel=subinstr("`bylabel'"," ","_",.)
257.                         local bylabels `bylabels' _`bylabel'
258.                 }
259.                 mata:saveVariancesToDataset(cov_lag_accum, corr_lag_accum,
>  obs_lag_accum, cov_se_lag_accum, var_total_accum, var_class_accum, var_ind_a
> ccum, cov_sameyear_accum, corr_sameyear_accum, obs_sameyear_accum, tokens(st_
> local("bylabels")))
260.         }
261.         else mata:saveVariancesToDataset(cov_lag_accum, corr_lag_accum, ob
> s_lag_accum, cov_se_lag_accum, var_total_accum, var_class_accum, var_ind_accu
> m, cov_sameyear_accum, corr_sameyear_accum, obs_sameyear_accum, "")
262.         if (`nooutput'!=1) qui outsheet using `"`output'_variance.csv"', c
> omma replace
263.         
.         * Load the correct output dataset
.         tokenize "`data'"
264.         if inlist("`1'","preserve","merge") {
265.                 restore
266.                 
.                 if (`merge_resid'==1) {
267.                         if ("`byvar'"!="") qui keep if missing(`teacher',`
> year',`class',`byvar')
268.                         else qui keep if missing(`teacher',`year',`class')
269.                         forvalues l=1/`by_vals' {
270.                                 append using `"`resid_data_`l''"', nolabel
271.                         }
272.                 }
273.                 if (`merge_tv'==1) qui merge m:1 `teacher' `year' `by' `ou
> tput_addvars' using `"`output'"', nogen nolabel
274.                 /* else "`data'"=="preserve", and that is already loaded. 
> */            
.         }
275.         else {
276.                 restore, not
277.                 
.                 if ("`data'"=="tv") use `"`output'"', clear
278.                 /* else "`data'"=="variance", and that is already loaded. 
> */            
.         }
279.         
.         * Close log
.         if (`nooutput'!=1) log close
280. 
. end

