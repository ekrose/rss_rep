. 
. *** Long-run outcome entry IVs
. dis "Working on short-run outcomes"
Working on short-run outcomes

. eststo clear

. local mcount = 1

. foreach outcome of varlist aoc_crim aoc_incar college_bound {
  2.         preserve 
  3.         global outcome "`outcome'"
  4.         fun_vam "${outcome}" 0 
  5. 
.         *** 1) IV tests of forecast bias
.         * Entry of new teacher into school grade
.         bys school_fe grade year: egen vam_entry_school_grade = mean(loo_ebar
> _schgrade) if nyears_teach_schgrd == 0 & nyears_schgrd >= 3
  6.         capture drop _tmp
  7.         gen _tmp = vam_entry_school_grade != .
  8.         bys school_fe grade year: egen any_entry_school_grade = max(_tmp)
  9.         drop _tmp
 10.         replace vam_entry_school_grade = 0 if vam_entry_school_grade == .
 11. 
.         * Entry of teacher into school
.         bys school_fe grade year: egen vam_entry_school = mean(loo_ebar_schoo
> l) if nyears_teach_school == 0 & nyears_schgrd >= 3
 12.         gen _tmp = vam_entry_school != .
 13.         bys school_fe grade year: egen any_entry_school = max(_tmp)
 14.         drop _tmp
 15.         replace vam_entry_school = 0 if vam_entry_school == .
 16. 
.         * Endogenous var
.         global lomvar "touse"
 17. 
.         * School-grade switchers
.         capture drop touse
 18.         gen touse = ebar_schgrade
 19. 
.         * School-grade switchers
.         eststo desiv`mcount': ivreg2 ${outcome} (${lomvar} = vam_entry_school
> _grade) any_entry_school_grade ${covdesign}, cluster(mastid) ffirst 
 20.         estadd local design_controls = "\checkmark" : desiv`mcount'
 21.         estadd local sgfe = "" : desiv`mcount'
 22.         estadd local ffirst = round(el(e(first),4,1),-1) : desiv`mcount'
 23.         test ${lomvar} = 1
 24.         estadd local pvalone = round(r(p),.001) : desiv`mcount'
 25.         local mcount = `mcount' + 1
 26. 
.         * School-switchers
.         capture drop touse
 27.         gen touse = ebar_school
 28. 
.         eststo desiv`mcount': ivreg2 ${outcome} (${lomvar} = vam_entry_school
> ) any_entry_school ${covdesign}, cluster(mastid) ffirst
 29.         estadd local design_controls = "\checkmark" : desiv`mcount'
 30.         estadd local sgfe = "" : desiv`mcount'
 31.         estadd local ffirst = round(el(e(first),4,1),-1) : desiv`mcount'
 32.         test ${lomvar} = 1
 33.         estadd local pvalone = round(r(p),.001) : desiv`mcount'
 34.         local mcount = `mcount' + 1
 35. 
.         restore
 36. }
