. *** 2) OVB tests for long-run academic outcomes
. eststo clear

. foreach outcome of varlist college_bound gpa_weighted {
  2.     capture drop xhat xhatd teach_fe
  3.     qui areg `outcome' ${covdesign}, abs(teachid)
  4.     local origr2 = e(r2)
  5.     predict xhat, xb
  6.     predict xhatd, xbd
  7.     gen teach_fe = xhatd - xhat
  8. 
.         
.         if "`outcome'" == "college_bound" {
  9.                 local figtitle "A3c"
 10.         }
 11.         if "`outcome'" == "gpa_weighted" {
 12.                 local figtitle "A3d"
 13.         }
 14. 
.     * Regression with all omitted
.     capture drop twin_fe covadj_predict
 15.     eststo: reghdfe `outcome' ${covsadj} ${covdesign}, absorb(teachid twin
> _fe=twins_all#grade#year, savefe)
 16.     estadd local design_controls = "\checkmark"
 17.     estadd local twin_fe = "\checkmark"
 18.     estadd local orig_r2 = round(`origr2',0.0001)
 19.     capture drop covadj_predict
 20.     mat b=e(b)
 21.     mat b=b[1,1..2]
 22.     mat score covadj_predict=b if e(sample) == 1
 23.     replace covadj_predict = covadj_predict + twin_fe
 24. 
.     eststo: reg covadj_predict ${regvar} ${covdesign}, cluster(mastid)
 25.     estadd local design_controls = "\checkmark"
 26.     local slopeCoef = round(_b[${regvar}], 0.0001)
 27.     local slopeSE = round(_se[${regvar}], 0.0001)
 28.     qui su covadj_predict if e(sample) == 1
 29.     replace covadj_predict = covadj_predict - r(mean)
 30. 
.         binscatter covadj_predict ${regvar}, controls(${covdesign}) xtitle("E
> stimated teacher effect") ytitle("Omitted variables fit") yscale(range(-0.025
>  0.025)) ylabel(-0.025(0.005)0.025) graphregion(color(white)) legend(off) not
> e("Slope: `slopeCoef' (`slopeSE')")
 31.         graph export figures/figure`figtitle'.pdf, replace
 32. }
