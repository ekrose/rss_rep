. assert e(sample) == 1    // All data is used for test score VA

. 
. * Save VCV and beta
. matrix beta = e(b)

. matrix sigma = e(V)

. 
. * Save fits to check procedure
. predict xb, xb 

. 
. * Create design matrix manually
. local beta_names : colnames beta

. local vcount = 1

. foreach col of local beta_names {
  2.     gen _x`vcount' = 1
  3.     tokenize "`col'", parse("#")
  4.     local i = 1
  5.     di ""
  6.     di "`col'"
  7.     while "``i''" != "" {
  8.         if "``i''" == "#" {
  9.         }
 10.         else {
 11.             tokenize "``i''", parse(".")
 12.             if "`3'" != "" {
 13.                 if ("`1'" != "c") | ("`1'" != "co") {
 14.                     if ("`1'" == "o") {
 15.                         di "multiplying by `3'"
 16.                         qui replace _x`vcount' = _x`vcount'*`3'
 17.                     }
 18.                     else {
 19.                         local ind : subinstr local 1 "b" "", all
 20.                         local ind : subinstr local ind "o" "", all
 21.                         local ind : subinstr local ind "c" "", all
 22.                         if ("`1'" == "c") | ("`1'" == "co") {
 23.                             di "multiplying by `3'"
 24.                             qui replace _x`vcount' = _x`vcount'*`3'       
>                      
 25.                         }
 26.                         else {
 27.                             di "multiplying by (`3' == `ind')"
 28.                             qui replace _x`vcount' = _x`vcount'*(`3' == `i
> nd')
 29.                         }
 30.                     }
 31.                 }
 32.                 else  {
 33.                     di "multiplying by `3'"
 34.                     qui replace _x`vcount' = _x`vcount'*`3'
 35.                 }
 36.             }
 37.             else {
 38.                 di "replacing with `col'"
 39.                 replace _x`vcount' = `col'
 40.             }
 41.             tokenize "`col'", parse("#")
 42.         }
 43.         local i = `i' + 1        
 44.     }
 45. 
.     local ++ vcount
 46. }

